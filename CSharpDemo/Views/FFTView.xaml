<UserControl
    x:Class="CSharpDemo.Views.FFTView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:CSharpDemo.ViewModels"
    x:Name="TargetUserControl"
    d:DataContext="{d:DesignInstance Type=vm:FFTViewModel}"
    d:DesignHeight="720"
    d:DesignWidth="1080"
    Background="{DynamicResource FirstBgBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <hc:TextBox
                x:Name="WavFileTextBox"
                Grid.Column="0"
                Margin="5"
                VerticalAlignment="Center"
                hc:InfoElement.ShowClearButton="True"
                Background="{DynamicResource ThirdBgBrush}"
                FontSize="16"
                Foreground="{DynamicResource ForegroundBrush}"
                Text="C:\Users\pengx\Desktop\相关仪测试数据目录\Audio\2024-10-18\听音_红_20241018_173335.wav" />

            <Button
                Grid.Column="1"
                Margin="0,0,5,0"
                Command="{Binding SelectWavFileCommand}"
                CommandParameter="{Binding ElementName=WavFileTextBox, Path=Text}"
                Content="选择音频"
                Style="{StaticResource ButtonPrimary}" />
        </Grid>

        <UniformGrid
            Grid.Row="1"
            Margin="5,0,5,5"
            Columns="2">
            <Grid Margin="0,0,2.5,0" Background="Black">
                <Path x:Name="StripsPath" />
            </Grid>

            <Grid
                x:Name="SampleWavePanel"
                Margin="2.5,0,0,0"
                Background="Black">
                <Path x:Name="SampleWavePath" />
            </Grid>
        </UniformGrid>
    </Grid>
</UserControl>