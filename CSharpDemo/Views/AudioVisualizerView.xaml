<UserControl
    x:Class="CSharpDemo.Views.AudioVisualizerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="720"
    d:DesignWidth="1080"
    Background="{DynamicResource FirstBgBrush}"
    Loaded="AudioWaveView_OnLoaded"
    Unloaded="AudioWaveView_OnUnloaded"
    mc:Ignorable="d">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="3*" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AudioCircularPanel"
            Grid.Row="0"
            Background="Black">
            <Path x:Name="CircularPath" />
        </Grid>

        <Grid
            x:Name="AudioWavePanel"
            Grid.Row="2"
            Background="Black">
            <Rectangle Name="TopBorder" VerticalAlignment="Top" />
            <Rectangle Name="BottomBorder" VerticalAlignment="Bottom" />
            <Rectangle Name="LeftBorder" HorizontalAlignment="Left" />
            <Rectangle Name="RightBorder" HorizontalAlignment="Right" />
            <Path x:Name="AudioWavePath" />
        </Grid>

        <Grid
            x:Name="AudioStripPanel"
            Grid.Row="4"
            Background="Black">
            <Path x:Name="StripsPath" />
        </Grid>
    </Grid>
</UserControl>